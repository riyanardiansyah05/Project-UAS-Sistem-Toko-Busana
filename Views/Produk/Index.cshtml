@model IEnumerable<TokoBusanaAlex.Models.Produk>

@{
    ViewData["Title"] = "Manajemen Produk";
}

<div class="container mt-5">
    <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
        <div class="card-body p-4 bg-gradient bg-dark text-white d-flex justify-content-between align-items-center">
            <div>
                <h2 class="fw-bold mb-1">Toko Busana Alex Sejahtera</h2>
                <p class="text-white-50 small mb-0">Manajemen Stok & Inventaris Produk Realtime</p>
            </div>
            <a asp-action="Create" class="btn btn-light text-dark fw-bold px-4 py-2 rounded-pill shadow-sm">
                ➕ Tambah Produk Baru
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 p-3">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-secondary text-uppercase fs-7 fw-semibold">
                    <tr>
                        <th class="ps-3">ID</th>
                        <th>Nama Produk</th>
                        <th>Kategori</th>
                        <th>Harga Satuan</th>
                        <th>Stok Ready</th>
                        <th class="text-center pe-3">Aksi Manajemen</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted fs-5">
                                📦 Belum ada data produk. Silakan tambah data baru.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3 fw-bold text-secondary">#@item.IdProduk</td>
                                <td>
                                    <div class="fw-bold text-dark fs-6">@item.NamaProduk</div>
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border px-3 py-2 rounded-pill fw-semibold">
                                        🛍️ @item.Kategori
                                    </span>
                                </td>
                                <td class="fw-bold text-success">Rp @item.Harga.ToString("N0")</td>
                                <td>
                                    @if(item.Stok <= 5) {
                                        <span class="badge bg-danger px-2.5 py-2 rounded-3">Hampir Habis: @item.Stok Pcs</span>
                                    } else {
                                        <span class="badge bg-dark px-2.5 py-2 rounded-3">@item.Stok Pcs</span>
                                    }
                                </td>
                                <td class="text-center pe-3">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-action="Edit" asp-route-id="@item.IdProduk" class="btn btn-sm btn-warning text-dark fw-semibold px-3 rounded-pill shadow-sm">
                                            ✏️ Edit
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.IdProduk" class="btn btn-sm btn-outline-danger fw-semibold px-3 rounded-pill" onclick="return confirm('Apakah Anda yakin ingin menghapus produk ini?')">
                                            🗑️ Hapus
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>